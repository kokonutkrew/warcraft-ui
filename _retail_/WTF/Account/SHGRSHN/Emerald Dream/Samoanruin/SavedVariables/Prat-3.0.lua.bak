					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						13, -- [3]
						14, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 260677.582,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [13]
				{
					["message"] = "|cff979797|Hpratcopy|h[20:06:58]|h|r Elisande says: I could not allow my people to starve, to waste away without its energies sustaining us. So a bargain was struck.",
					["serverTime"] = 1652753218,
					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						13, -- [3]
						14, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 260690.572,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [14]
				{
					["message"] = "|cff979797|Hpratcopy|h[20:07:08]|h|r Elisande says: Now I see a future where the Legion is victorious and my people endure. This is the thread that must be preserved. I will do everything in my power to make it so!",
