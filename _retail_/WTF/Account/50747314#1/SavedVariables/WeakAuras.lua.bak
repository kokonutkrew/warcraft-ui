							}, -- [1]
							{
								["trigger"] = 1,
								["variable"] = "isCompleted",
								["value"] = 0,
							}, -- [2]
						},
					},
					["changes"] = {
						{
							["value"] = {
								0, -- [1]
								1, -- [2]
								0.023529414087534, -- [3]
								1, -- [4]
							},
