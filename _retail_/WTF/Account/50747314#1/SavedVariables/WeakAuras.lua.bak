						["subeventSuffix"] = "_CAST_START",
						["events"] = "DRAGONFLIGHT_EVENT_TRACKER,START",
						["custom"] = "--code sampled and edited from the original WA by putro https://wago.io/fTuRJ__jk--\n-- Feast timer\nfunction(allstates, event, id)\n  \n  \n  local resettimer = 180 --aura_env.config.fbre -- need to finish adding this varibles in custom  options\n  local Rtime = resettimer * 60 -- multiply mins by secs and assign total secs\n  local ActiveDrutation = 120 --aura_env.config.sdur  -- need to finish adding this varibles in custom  options\n  local Atime = ActiveDrutation *60 -- multiply mins by secs and assign total secs\n  local Toffset = aura_env.config.timers.Stormoffset\n  local breaktime = Rtime\n  local duration = Atime\n  local Offsetmins = aura_env.config.timers.sOffsetammout -- get off set amount in mins\n  local Offsetpush = Offsetmins * 60-- multiply mins by secs and assign total secs\n  \n  local GMT1 = GetCurrentRegion() == 3\n  local settime1 = GMT1 and 1670342400 or 1670338800 --or 1670698800 or 1670677200;\n  if Toffset then\n    settime1 = settime1 + Offsetpush\n  end\n  local ttnf = breaktime - ((GetServerTime() - settime1) % breaktime)\n  local running = breaktime - ttnf < duration\n  local remaining = duration - (breaktime - ttnf)  \n  if event == \"DRAGONFLIGHT_EVENT_TRACKER\" and id == aura_env.id\n  or event == \"STATUS\"\n  then\n    allstates[\"\"] =  { \n      changed = true, \n      show = true, \n      progressType = \"timed\", \n      autoHide = true,\n      duration = running and duration or breaktime,\n      expirationTime = GetTime() + (running and remaining or ttnf),\n      icon = 4554441,\n      active = running\n    }\n    \n    return true\n  end\nend",
						["spellIds"] = {
						},
						["check"] = "event",
						["use_unit"] = true,
						["unit"] = "player",
						["customVariables"] = "{\n    active = {\n        display = \"tTigger\",\n        type = \"bool\",\n    }\n}",
