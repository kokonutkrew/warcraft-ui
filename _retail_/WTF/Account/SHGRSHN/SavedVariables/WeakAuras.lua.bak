				["ignoreOptionsEventErrors"] = true,
			},
			["customText"] = "function()\n    --Translit Edit\nend",
			["shadowYOffset"] = -1,
			["crop_x"] = 0.41,
			["desaturateBackground"] = false,
			["shadowColor"] = {
				0, -- [1]
