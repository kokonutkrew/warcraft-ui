				}, -- [10]
				{
					["message"] = "|cff979797|Hpratcopy|h[20:06:24]|h|r Elisande says: I foresaw your coming, of course. The threads of fate that led you to this place. Your desperate attempt to stop the Legion.",
					["serverTime"] = 1652753184,
