					["alphaType"] = "custom",
					["colorA"] = 1,
					["colorG"] = 1,
					["alphaFunc"] = "function(progress, start, delta)\n    \n    if aura_env.config[\"ShowOnKeyPress\"] then\n        \n        if aura_env.config[\"KeyOption\"] == 1 then\n            if IsLeftAltKeyDown() then\n                aura_env.region:Color(255,255,255,255)\n                return 1\n            else\n                aura_env.region:Color(255,255,255,0)\n                return 0\n            end\n        elseif  aura_env.config[\"KeyOption\"] == 2 then\n            if IsLeftShiftKeyDown() then\n                aura_env.region:Color(255,255,255,255)\n                return 1\n            else\n                aura_env.region:Color(255,255,255,0)\n                return 0\n            end\n        else\n            if IsLeftControlKeyDown() then\n                aura_env.region:Color(255,255,255,255)\n                return 1\n            else\n                aura_env.region:Color(255,255,255,0)\n                return 0\n            end\n        end\n    end \nend\n\n\n",
