				["finish"] = {
				},
				["init"] = {
					["custom"] = "-- Spy Found - On Init\n\naura_env.foundText = {\n    de=\"Na, na, wir wollen doch nicht voreilig sein\",\n    en=\"Now now, let's not be hasty\",\n    es=\"Calma, no nos apuremos\",\n    fr=\"que nous puissions en parler en privé\",\n}\naura_env.displayText = {\n    de=\"SPION GEFUNDEN!\",\n    en=\"SPY FOUND!\",\n    es=\"¡ESPIA ENCONTRADO!\",\n    fr=\"ESPION TROUVÉ!\",\n}",
					["do_custom"] = true,
