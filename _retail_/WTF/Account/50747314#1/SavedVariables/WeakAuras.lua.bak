		["Elemental Storm: Earth"] = {
			["sparkWidth"] = 10,
			["sparkOffsetX"] = 0,
			["wagoID"] = "9MpDLGWp3",
			["parent"] = "Primals Module (off by default turn on in Custom options)",
			["preferToUpdate"] = false,
			["customText"] = "function()\n    return aura_env.zone\nend",
			["yOffset"] = 0,
			["anchorPoint"] = "CENTER",
			["semver"] = "4.10.6",
			["sparkRotation"] = 0,
			["sparkRotationMode"] = "AUTO",
			["url"] = "https://wago.io/TamasDragonflightHelper/74",
			["icon"] = true,
			["triggers"] = {
				{
					["trigger"] = {
						["use_alwaystrue"] = true,
						["use_absorbMode"] = true,
						["unit"] = "player",
						["debuffType"] = "HELPFUL",
						["type"] = "custom",
						["use_absorbHealMode"] = true,
						["subeventSuffix"] = "_CAST_START",
						["custom_hide"] = "custom",
						["event"] = "Conditions",
						["events"] = "START, CHAT_MSG_LOOT,PARTY_KILL,BAG_UPDATE,QUEST_COMPLETE,QUEST_AUTOCOMPLETE,WORLD_QUEST_COMPLETED_BY_SPELL,UPDATE_FACTION,QUEST_LOG_UPDATE,ENCOUNTER_LOOT_RECEIVED,QUEST_TURNED_IN,QUEST_LOG_UPDATE",
						["customDuration"] = "function()\n    return 0, 100, true\nend",
						["spellIds"] = {
						},
						["custom"] = "function()\n    if not aura_env.config[\"timers\"].primalStorm then return false end\n    \n    -- iterate zones\n    for zoneID in pairs(aura_env.zoneID) do\n        \n        --iterate POI elements\n        for _, poi in ipairs(C_AreaPoiInfo.GetAreaPOIForMap(zoneID)) do\n            \n            -- is elemental storm up AND is this the zone\n            if C_AreaPoiInfo.GetAreaPOIInfo(zoneID,poi).name == \"Elemental Storm\" and C_AreaPoiInfo.GetAreaPOIInfo(zoneID,poi).isPrimaryMapForPOI then\n                local n = C_AreaPoiInfo.GetAreaPOIInfo(zoneID,poi).atlasName\n                local f = select(1,strsplit(\"-\",n))\n                \n                -- check for the storm we care about\n                if f == \"ElementalStorm\" then\n                    if select(3,strsplit(\"-\",n)) == \"Earth\" then\n                        aura_env.zone = aura_env.zoneID[zoneID]\n                        return true\n                    end\n                end\n            end\n        end\n    end\nend",
						["custom_type"] = "status",
						["check"] = "event",
						["subeventPrefix"] = "SPELL",
