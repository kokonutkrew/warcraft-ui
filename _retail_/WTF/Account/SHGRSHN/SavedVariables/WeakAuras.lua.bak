			["source"] = "import",
			["mirror"] = false,
			["authorOptions"] = {
				{
					["type"] = "header",
					["useName"] = true,
					["text"] = "ASSIGNMENT OPTIONS",
					["noMerge"] = false,
					["width"] = 1,
				}, -- [1]
				{
					["desc"] = "Allows you to assign a preferred position for melees",
					["type"] = "select",
					["values"] = {
						"LEFT", -- [1]
						"RIGHT", -- [2]
					},
					["default"] = 1,
					["key"] = "meleeSide",
					["useDesc"] = true,
					["name"] = "Melees",
					["width"] = 0.35,
				}, -- [2]
				{
					["desc"] = "There will sometimes be an uneven amount of debuff applications.|nTherefore you need to specify if the additional amount of players have to go left or right.",
					["type"] = "select",
					["values"] = {
						"More left", -- [1]
						"More right", -- [2]
					},
					["default"] = 1,
					["key"] = "ratio",
