			["customTextUpdate"] = "event",
			["url"] = "https://wago.io/TamasDragonflightHelper/74",
			["backgroundColor"] = {
				0, -- [1]
				0.098039224743843, -- [2]
				0.8156863451004, -- [3]
				0.5, -- [4]
			},
			["triggers"] = {
				{
					["trigger"] = {
						["use_alwaystrue"] = true,
						["use_absorbMode"] = true,
						["unit"] = "player",
						["debuffType"] = "HELPFUL",
						["type"] = "custom",
						["use_absorbHealMode"] = true,
						["subeventSuffix"] = "_CAST_START",
						["custom_hide"] = "custom",
						["event"] = "Conditions",
						["events"] = "START, CHAT_MSG_LOOT,PARTY_KILL,BAG_UPDATE,QUEST_COMPLETE,QUEST_AUTOCOMPLETE,WORLD_QUEST_COMPLETED_BY_SPELL,UPDATE_FACTION,QUEST_LOG_UPDATE,ENCOUNTER_LOOT_RECEIVED,QUEST_TURNED_IN,QUEST_LOG_UPDATE",
						["customDuration"] = "function()\n    return 0, 100, true\nend",
						["spellIds"] = {
						},
						["custom"] = "function()\n  if not aura_env.config[\"timers\"].primalStorm then return false end\n  \n  -- iterate zones\n  for zoneID in pairs(aura_env.zoneID) do\n    \n    --iterate POI elements\n    for _, poi in ipairs(C_AreaPoiInfo.GetAreaPOIForMap(zoneID)) do\n      \n      -- is elemental storm up AND is this the zone\n      if C_AreaPoiInfo.GetAreaPOIInfo(zoneID,poi).name == \"Elemental Storm\" and C_AreaPoiInfo.GetAreaPOIInfo(zoneID,poi).isPrimaryMapForPOI then\n        local n = C_AreaPoiInfo.GetAreaPOIInfo(zoneID,poi).atlasName\n        local f = select(1,strsplit(\"-\",n))\n        \n        -- check for the storm we care about\n        if f == \"ElementalStorm\" then\n          if select(3,strsplit(\"-\",n)) == \"Water\" then\n            aura_env.zone = aura_env.zoneID[zoneID]\n            return true\n          end\n        end\n      end\n    end\n  end\nend\n\n\n\n",
