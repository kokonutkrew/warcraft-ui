					["untrigger"] = {
						["custom"] = "function(event, ...)\n    if (event == \"COMBAT_LOG_EVENT_UNFILTERED\") then\n        local _,subEvent,_,_,_,_,_,_,destName,_,_,spellId,_,_,_ = ...\n        if (subEvent == \"SPELL_AURA_REMOVED\" and spellId == 354964 and destName == WeakAuras.me) then\n            return true\n        end\n    end\nend\n\n\n",
					},
