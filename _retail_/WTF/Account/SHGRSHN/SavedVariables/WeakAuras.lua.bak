						["unit"] = "player",
						["check"] = "update",
						["custom_type"] = "status",
						["custom"] = "function()\n    local time_cur = GetTime()\n    if (time_cur - aura_env.TIMER) > 3 then\n        aura_env.TIMER = time_cur\n        RequestBattlefieldScoreData()\n    end\n    return true\nend",
						["debuffType"] = "HELPFUL",
