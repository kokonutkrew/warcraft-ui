					["g"] = 1,
					["r"] = 1,
				}, -- [14]
				{
					["message"] = "|cff979797|Hpratcopy|h[19:59:02]|h|r Captain Fareeya says: For thousands of years, the Lightforged fought demons in the Twisting Nether. The Xenedar was the only home we knew.",
