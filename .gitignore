# Ignore all
*

# Except for advanced tracking rules
!*/

# Track specific files
!/.gitignore
!/.gitmodules

################################################################################
# ＫＯＫＯＮＵＴＫＲＥＷ
################################################################################

!\#kokonutkrew/*.txt
!\#kokonutkrew/hotkeynet/AutoExec.xml
!\#kokonutkrew/hotkeynet/hkn_settings.txt
!\#kokonutkrew/overwolf/Overwolf.exe.config
!\#kokonutkrew/tsm/*.txt
!\#kokonutkrew/ui-ide/**
!\#kokonutkrew/warcraft-logs/*.txt
!\#kokonutkrew/weak-aura-backup/**
!\#kokonutkrew/wowhead/*.txt
!\#kokonutkrew/wow-open-box/*.bat
!\#kokonutkrew/wow-open-box/*.tcl

################################################################################
# Retail
################################################################################

# Track specific addons
!_retail_/Interface/AddOns/\[KK\]/**

# Track Config files
!_retail_/WTF/*.wtf

# Track addon data
!_retail_/WTF/Account/**/SavedVariables/**
!_retail_/WTF/Account/**/**/**/SavedVariables/**

# Whenever settings are downloaded from the server,
# the old settings are saved in <file>.old. Log out, 
# move them back into place and they'll be uploaded to
# Blizzard servers.

# Track settings that require an upload to Blizzard servers
!_retail_/WTF/Account/*/*.txt
!_retail_/WTF/Account/*/*.wtf
!_retail_/WTF/Account/*/*/*/*.txt
!_retail_/WTF/Account/*/*/*/bindings-cache.wtf

