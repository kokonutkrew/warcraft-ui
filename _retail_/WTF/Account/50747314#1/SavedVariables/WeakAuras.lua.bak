		["BGtd"] = {
			["user_y"] = 0,
			["user_x"] = 0,
			["authorOptions"] = {
			},
			["preferToUpdate"] = false,
			["yOffset"] = 13,
			["foregroundColor"] = {
				1, -- [1]
				1, -- [2]
