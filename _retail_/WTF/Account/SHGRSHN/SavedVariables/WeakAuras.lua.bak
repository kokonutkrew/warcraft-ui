			["parent"] = "Herb Module",
			["information"] = {
				["forceEvents"] = false,
				["ignoreOptionsEventErrors"] = true,
			},
			["customText"] = "function()\n    --Translit Edit\nend",
			["shadowYOffset"] = -1,
			["crop_x"] = 0.41,
			["desaturateBackground"] = false,
			["shadowColor"] = {
				0, -- [1]
				0, -- [2]
				0, -- [3]
				1, -- [4]
			},
			["color"] = {
				1, -- [1]
