						["debuffType"] = "HELPFUL",
						["custom_hide"] = "custom",
						["use_absorbMode"] = true,
						["type"] = "custom",
						["use_absorbHealMode"] = true,
						["subeventSuffix"] = "_CAST_START",
						["spellIds"] = {
						},
						["events"] = "PLAYER_REGEN_DISABLED ENCOUNTER_START",
						["event"] = "Combat Log",
						["custom_type"] = "event",
