					["duration_type"] = "seconds",
					["colorB"] = 1,
					["colorFunc"] = "function()\n    if aura_env.config.GCDRingClassColor then\n        local c = RAID_CLASS_COLORS[select(2,UnitClass(\"player\"))]\n        return c.r, c.g, c.b\n    end\n    \nend",
