					["g"] = 1,
					["r"] = 1,
				}, -- [15]
				{
					["message"] = "|cff979797|Hpratcopy|h[19:59:14]|h|r Captain Fareeya says: Now, for the first time in ages, we can walk beneath a sky not befouled by the Legion's madness... and feel the earth under our hooves again.",
