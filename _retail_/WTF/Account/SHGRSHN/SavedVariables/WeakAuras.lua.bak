				}, -- [4]
				["disjunctive"] = "custom",
				["customTriggerLogic"] = "function(trigger)\n    return trigger[1] or trigger[2]\nend",
				["activeTriggerMode"] = 3,
			},
			["endAngle"] = 360,
			["internalVersion"] = 64,
			["foregroundColor"] = {
