					["timestamp"] = 277600.773,
					["g"] = 0.501960813999176,
					["b"] = 0.250980406999588,
				}, -- [63]
				{
					["message"] = "|Hpratcopy|h[12:48]|h Elisande says: I foresaw your coming, of course. The threads of fate that led you to this place. Your desperate attempt to stop the Legion.",
					["serverTime"] = 1652770133,
					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						20, -- [3]
						21, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 277605.802,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [64]
				{
					["message"] = "|Hpratcopy|h[12:49]|h Elisande says: My people faced a similar dilemma. I peered into all possible futures in search of an answer... and found only one.",
					["serverTime"] = 1652770143,
					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						20, -- [3]
						21, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 277615.772,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [65]
				{
					["message"] = "|Hpratcopy|h[12:49]|h Elisande says: The Legion's victory is inevitable. Every time stream shows it to be so. Had we resisted, they would have taken the Nightwell by force and left us bereft of it.",
					["serverTime"] = 1652770154,
					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						20, -- [3]
						21, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 277626.77,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [66]
				{
					["message"] = "|Hpratcopy|h[12:49]|h Elisande says: I could not allow my people to starve, to waste away without its energies sustaining us. So a bargain was struck.",
					["serverTime"] = 1652770167,
					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						20, -- [3]
						21, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 277639.782,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [67]
				{
					["message"] = "|Hpratcopy|h[12:49]|h Elisande says: Now I see a future where the Legion is victorious and my people endure. This is the thread that must be preserved. I will do everything in my power to make it so!",
					["serverTime"] = 1652770177,
					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						20, -- [3]
						21, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 277649.767,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [68]
				{
					["message"] = "|Hpratcopy|h[12:49]|h Elisande says: Your deaths ensure the future of the Nightborne. Come forward, then. Let us speed you toward your fate.",
					["serverTime"] = 1652770191,
