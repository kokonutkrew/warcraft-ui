			},
			["displayText"] = "%c",
			["customText"] = "-- Spy Found - Display\n\nfunction()\n    if not aura_env then\n        return false\n    end\n    local locale = GetLocale()\n    local language = string.sub(locale, 1, 2)\n    local foundTextLoc = aura_env.displayText[language] or aura_env.displayText[\"en\"]\n    return foundTextLoc\nend",
			["shadowYOffset"] = -1,
			["anchorPoint"] = "CENTER",
