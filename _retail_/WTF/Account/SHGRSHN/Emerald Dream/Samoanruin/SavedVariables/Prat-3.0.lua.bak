					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [11]
				{
					["message"] = "|cff979797|Hpratcopy|h[20:06:34]|h|r Elisande says: My people faced a similar dilemma. I peered into all possible futures in search of an answer... and found only one.",
					["serverTime"] = 1652753194,
					["r"] = 1,
					["extraData"] = {
						13, -- [1]
						false, -- [2]
						13, -- [3]
						14, -- [4]
						["n"] = 4,
					},
					["timestamp"] = 260666.58,
					["g"] = 1,
					["b"] = 0.6235294342041016,
				}, -- [12]
				{
					["message"] = "|cff979797|Hpratcopy|h[20:06:45]|h|r Elisande says: The Legion's victory is inevitable. Every time stream shows it to be so. Had we resisted, they would have taken the Nightwell by force and left us bereft of it.",
