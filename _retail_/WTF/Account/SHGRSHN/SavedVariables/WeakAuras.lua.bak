				{
					["trigger"] = {
						["type"] = "custom",
						["custom"] = "function()\n    \n    if not aura_env.last or aura_env.last < GetTime() - 2 then\n        aura_env.last = GetTime()\n        \n        local state = WeakAuras.GetTriggerStateForTrigger(aura_env.id, 2)\n        if state then \n            for unit, table in pairs(state) do\n                if UnitIsVisible(unit) then \n                    aura_env.trigger3 = true\n                    return true\n                end\n            end\n        end\n        \n        aura_env.trigger3 = false\n    end\n    \n    return aura_env.trigger3\nend\n\n\n\n",
						["custom_type"] = "status",
						["check"] = "update",
						["unit"] = "player",
						["debuffType"] = "HELPFUL",
