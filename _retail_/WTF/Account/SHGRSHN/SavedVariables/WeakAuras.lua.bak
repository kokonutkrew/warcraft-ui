			["yOffset"] = -42,
			["anchorPoint"] = "CENTER",
			["cooldownSwipe"] = true,
			["cooldownEdge"] = false,
			["icon"] = true,
			["triggers"] = {
				{
					["trigger"] = {
						["type"] = "custom",
						["subeventSuffix"] = "_CAST_START",
						["event"] = "Health",
						["unit"] = "player",
						["names"] = {
						},
						["spellIds"] = {
						},
						["events"] = "HYLB_TOPLEFT HYLB_TOPRIGHT HYLB_BOTTOMLEFT HYLB_BOTTOMRIGHT HYLB_RESET",
						["subeventPrefix"] = "SPELL",
						["check"] = "event",
						["custom_type"] = "stateupdate",
						["custom"] = "function(states, event, arg1, arg2, arg3)\n    if event == \"OPTIONS\" then\n        states[\"\"] = {\n            text = \"\",\n            icon = 1323038,\n            progressType = \"static\",\n            changed = true,\n            show = true\n        }\n        return true\n    end\n    if event == \"HYLB_BOTTOMLEFT\" and arg1 and arg2 then\n        states[\"\"] = {\n            text = arg2,\n            icon = arg1,\n            progressType = \"static\",\n            changed = true,\n            show = true\n        }\n        aura_env.handle()\n        return true\n    elseif event == \"HYLB_RESET\" and arg1 then\n        aura_env.handle(true)\n        if states[\"\"] then\n            states[\"\"].show = false\n            states[\"\"].changed = true\n        end\n        return true\n    elseif (event == \"HYLB_TOPLEFT\" or event == \"HYLB_TOPRIGHT\" or event == \"HYLB_BOTTOMRIGHT\") and arg3 then\n        aura_env.region[\"button\"..arg3]:Hide()\n    end\nend",
						["debuffType"] = "HELPFUL",
					},
					["untrigger"] = {
					},
				}, -- [1]
				{
					["trigger"] = {
