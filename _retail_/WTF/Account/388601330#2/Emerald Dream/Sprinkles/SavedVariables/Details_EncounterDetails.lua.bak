
EncounterDetailsDB = {
	["emotes"] = {
		{
			{
				1.232000000018161, -- [1]
				"|TInterface\\Icons\\Spell_Fire_FelPyroblast:20|t %s begins to cast |cFFFF0000|Hspell:206219|h[Liquid Hellfire]|h|r.", -- [2]
				"Gul'dan", -- [3]
				1, -- [4]
			}, -- [1]
			{
				6.038999999989756, -- [1]
				"Strike for Sargeras!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [2]
			{
				10.05300000001444, -- [1]
				"Burn from within!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [3]
			{
				20.04200000001583, -- [1]
				"Rid me of these pests!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [4]
			{
				30.04599999997299, -- [1]
				"Kill them in my master's name!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [5]
			{
				34.06500000000233, -- [1]
				"The vessel must be made ready!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [6]
			{
				40.22899999999208, -- [1]
				"|TInterface\\Icons\\Spell_Fire_FelPyroblast:20|t %s begins to cast |cFFFF0000|Hspell:206219|h[Liquid Hellfire]|h|r.", -- [2]
				"Gul'dan", -- [3]
				1, -- [4]
			}, -- [7]
			{
				40.22899999999208, -- [1]
				"I'll make ashes of you!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [8]
			{
				40.51799999998184, -- [1]
				"You failed, heroes! The ritual is upon us! But first, I'll indulge myself a bit... and finish you!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [9]
			{
				61.00599999999395, -- [1]
				"A taste of the master's might!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [10]
			{
				65.72499999997672, -- [1]
				"|TInterface\\Icons\\ability_felarakkoa_feldetonation_red:20|t %s gains |cFFFF0000|Hspell:206221|h[Empowered Bonds of Fel]|h|r.", -- [2]
				"Gul'dan", -- [3]
				1, -- [4]
			}, -- [11]
			{
				65.72499999997672, -- [1]
				"You'll never escape my grasp!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [12]
			{
				74.21299999998882, -- [1]
				"|TInterface\\Icons\\Spell_Fire_FelFlameStrike:20|t %s gains |cFFFF0000|Hspell:206220|h[Empowered Liquid Hellfire]|h|r.", -- [2]
				"Gul'dan", -- [3]
				1, -- [4]
			}, -- [13]
			{
				74.21299999998882, -- [1]
				"Drink in the glory!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [14]
			{
				79.01600000000326, -- [1]
				"|TInterface\\Icons\\inv_misc_trinket6oih_orb1:20|t %s gains |cFFFF0000|Hspell:211152|h[Empowered Eye of Gul'dan]|h|r.", -- [2]
				"Gul'dan", -- [3]
				1, -- [4]
			}, -- [15]
			{
				79.01600000000326, -- [1]
				"I will not fail you, master! More power... just need more power...", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [16]
			{
				82.75199999997858, -- [1]
				"No more distractions! I have work to do...", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [17]
			{
				97.20899999997346, -- [1]
				"Surrender! I may yet show mercy!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [18]
			{
				104.5169999999926, -- [1]
				"Time to return the demon hunter's soul to his body... and deny the Legion's master a host!", -- [2]
				"Archmage Khadgar", -- [3]
				7, -- [4]
			}, -- [19]
			{
				109.4149999999791, -- [1]
				"We can stop him! I know it!", -- [2]
				"Archmage Khadgar", -- [3]
				7, -- [4]
			}, -- [20]
			{
				111.5299999999697, -- [1]
				"Burn from within!", -- [2]
				"Gul'dan", -- [3]
				7, -- [4]
			}, -- [21]
			{
				114.2760000000126, -- [1]
				"Keep pressing, champions! Gul'dan wavers! He WILL fall!", -- [2]
				"Archmage Khadgar", -- [3]
				7, -- [4]
			}, -- [22]
			["boss"] = "Gul'dan",
		}, -- [1]
		{
			{
				16.5789999999688, -- [1]
				"You exist in but a single moment. I am far less limited!", -- [2]
				"Elisande", -- [3]
				7, -- [4]
			}, -- [1]
			{
				31.29899999999907, -- [1]
				"You were destined to die.", -- [2]
				"Elisande", -- [3]
				7, -- [4]
			}, -- [2]
			{
				43.27799999999115, -- [1]
				"Time shifts again, and your doom draws near!", -- [2]
				"Elisande", -- [3]
				7, -- [4]
			}, -- [3]
			{
				65.25699999998324, -- [1]
				"Time is... slipping away! How can it be so?", -- [2]
				"Elisande", -- [3]
				7, -- [4]
			}, -- [4]
			{
				73.56699999998091, -- [1]
				"It's... not possible! I... I was destined to win...", -- [2]
				"Elisande", -- [3]
				7, -- [4]
			}, -- [5]
			["boss"] = "Grand Magistrix Elisande",
		}, -- [2]
		{
			{
				0.2289999999920838, -- [1]
				"You think getting past a few power-addled elves means you can stand against a true son of the Legion?", -- [2]
				"Tichondrius", -- [3]
				7, -- [4]
			}, -- [1]
			{
				20.31199999997625, -- [1]
				"Feed my hunger, wretch!", -- [2]
				"Tichondrius", -- [3]
				7, -- [4]
			}, -- [2]
			["boss"] = "Tichondrius",
		}, -- [3]
